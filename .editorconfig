root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{java,ts,tsx,js,jsx}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.java]
max_line_length = 150

[*.{json,yml,yaml}]
indent_size = 2
max_line_length = 150

[*.md]
trim_trailing_whitespace = false

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ganglia Configuration Contract",
  "description": "The configuration schema for the Ganglia agent framework.",
  "type": "object",
  "properties": {
    "agent": {
      "type": "object",
      "properties": {
        "maxIterations": { "type": "integer", "default": 10 },
        "compressionThreshold": { "type": "number", "default": 0.7 },
        "projectRoot": { "type": "string" }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "temperature": { "type": "number" },
          "maxTokens": { "type": "integer" },
          "contextLimit": { "type": "integer" },
          "type": { "type": "string", "enum": ["openai", "anthropic", "gemini"] },
          "apiKey": { "type": "string" },
          "baseUrl": { "type": "string" },
          "stream": { "type": "boolean" }
        },
        "required": ["name", "type"]
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "tracePath": { "type": "string" }
      }
    },
    "webui": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "default": 8080 },
        "enabled": { "type": "boolean", "default": true },
        "webroot": { "type": "string" }
      }
    }
  }
}

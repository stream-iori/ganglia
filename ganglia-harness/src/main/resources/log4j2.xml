<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
    </Console>
    <RollingFile name="DebugFile" fileName=".ganglia/logs/debug.log"
                 filePattern=".ganglia/logs/debug-%d{yyyy-MM-dd}.log.gz">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
      <Policies>
        <TimeBasedTriggeringPolicy />
        <SizeBasedTriggeringPolicy size="100 MB"/>
      </Policies>
      <DefaultRolloverStrategy max="10"/>
    </RollingFile>
    <RollingFile name="LLMLogFile" fileName=".ganglia/logs/llm-request.log"
                 filePattern=".ganglia/logs/llm-request-%i.log.gz">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} - %msg%n"/>
      <Policies>
        <SizeBasedTriggeringPolicy size="1 GB"/>
      </Policies>
      <DefaultRolloverStrategy max="5"/>
    </RollingFile>
  </Appenders>
  <Loggers>
    <Logger name="LLM_LOG" level="info" additivity="false">
      <AppenderRef ref="LLMLogFile"/>
    </Logger>
    <Logger name="me.stream.ganglia.core.llm" level="debug" additivity="false">
      <AppenderRef ref="Console" level="info"/>
      <AppenderRef ref="DebugFile"/>
    </Logger>
    <Logger name="me.stream.ganglia.tools" level="debug" additivity="false">
      <AppenderRef ref="Console" level="info"/>
      <AppenderRef ref="DebugFile"/>
    </Logger>
    <Logger name="work.ganglia" level="debug" additivity="false">
      <AppenderRef ref="Console" level="info"/>
      <AppenderRef ref="DebugFile"/>
    </Logger>
    <Logger name="me.stream" level="debug" additivity="false">
      <AppenderRef ref="Console" level="info"/>
      <AppenderRef ref="DebugFile"/>
    </Logger>
    <Root level="info">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
